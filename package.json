{
  "name": "simvex-ts-rewrite",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "dev": "npm run -ws dev",
    "lint": "npm run -ws lint",
    "typecheck": "npm run -ws typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate:local": "cross-env DATABASE_URL=postgres://dosacha:dosacha@localhost:5432/simvex npm run migrate -w @simvex/api",
    "db:smoke:local": "cross-env DATABASE_URL=postgres://dosacha:dosacha@localhost:5432/simvex npm run db:smoke -w @simvex/api",
    "dev:api:pg": "cross-env SIMVEX_REPOSITORY_DRIVER=postgres DATABASE_URL=postgres://dosacha:dosacha@localhost:5432/simvex SIMVEX_JWT_SECRET=local-dev-only-jwt-secret-do-not-use-in-stage-or-prod npm run dev -w @simvex/api",
    "rehearsal:stage": "npm run rehearsal:check -w @simvex/api && npm run migrate:validate -w @simvex/api && npm run db:smoke -w @simvex/api && npm run test:unit -w @simvex/api"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "cross-env": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}