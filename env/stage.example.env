NODE_ENV=staging
SIMVEX_REPOSITORY_DRIVER=postgres
DATABASE_URL=postgres://<stage_user>:<stage_password>@<stage_db_host>:5432/<stage_db_name>
SIMVEX_CORS_ORIGINS=https://stage.simvex.com
# JWT 서명/검증 secret. 최소 32자. 평문 커밋 금지 — 배포 플랫폼 Secret 으로만 주입.
# 생성: openssl rand -base64 48
SIMVEX_JWT_SECRET=<stage_jwt_secret_min_32_chars>
PORT=8080
HOST=0.0.0.0