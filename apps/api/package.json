{
  "name": "@simvex/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/lambda/index.mjs --external:pg-native --external:@aws-sdk/* --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/server.js",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:validate": "tsx scripts/validate-migrations.ts",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "rehearsal:check": "tsx scripts/check-stage-env.ts",
    "test": "npm run test:unit && npm run test:postgres",
    "test:unit": "tsx --test src/core/catalog.test.ts src/core/repository.test.ts src/modules/api-contract.test.ts",
    "test:postgres": "tsx --test src/core/repository-postgres.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"no lint yet\""
  },
  "dependencies": {
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@simvex/shared": "0.1.0",
    "fastify": "^5.0.0",
    "pg": "^8.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.6",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}
